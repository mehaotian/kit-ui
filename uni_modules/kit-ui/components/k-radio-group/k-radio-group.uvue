<script setup lang="uts">
	import { inject, computed, ref, watch, type ComputedRef } from 'vue'
	import { buildThemeStyle } from '../../utils/theme.uts'
	import { K_FORM_ITEM_VALIDATE_TRIGGER_KEY, K_FORM_ITEM_DISABLED_KEY } from '../k-form/form-context.uts'

	/**
	 * k-radio-group 单选框组
	 * 管理一组 k-radio 的选中值，支持水平/垂直布局与按钮形态
	 */

	type KRadioGroupProps = {
		modelValue ?: string | number
		disabled ?: boolean
		direction ?: string
		size ?: string
		shape ?: string
		iconPlacement ?: string
		customStyle ?: string
	}

	const props = withDefaults(defineProps<KRadioGroupProps>(), {
		modelValue: '',
		disabled: false,
		direction: 'horizontal',
		size: 'medium',
		shape: 'dot',
		iconPlacement: 'left',
		customStyle: ''
	})

	const emit = defineEmits<{
		'update:modelValue' : [value: string | number]
		change : [value: string | number]
	}>()

	const themeConfig = inject('kit-theme', {})
	const validateByTrigger = inject<((trigger : string) => boolean) | null>(
		K_FORM_ITEM_VALIDATE_TRIGGER_KEY,
		null
	)
	const formItemDisabled = inject<ComputedRef<boolean> | null>(K_FORM_ITEM_DISABLED_KEY, null)

	/**
	 * 组内共享选中值（本地 ref 保证 APP 端子项立即联动更新）
	 */
	const innerValue = ref<string | number>(props.modelValue)

	/**
	 * 同步外部 v-model 到组内 ref
	 */
	watch((): string | number => props.modelValue, (value: string | number) => {
		if (innerValue.value != value) {
			innerValue.value = value
		}
	})

	/**
	 * 注入主题 CSS 变量到组件根节点
	 */
	const wrapperThemeStyle = computed((): string => {
		return buildThemeStyle(themeConfig, props.customStyle)
	})

	/**
	 * 组级禁用状态（组件 disabled 或表单项禁用）
	 */
	const resolvedGroupDisabled = computed((): boolean => {
		if (props.disabled) {
			return true
		}
		if (formItemDisabled != null && formItemDisabled.value) {
			return true
		}
		return false
	})

	/**
	 * 更新选中值并触发事件
	 */
	const updateValue = (value: string | number) => {
		if (resolvedGroupDisabled.value) {
			return
		}
		if (innerValue.value == value) {
			return
		}
		innerValue.value = value
		emit('update:modelValue', value)
		emit('change', value)
		if (validateByTrigger != null) {
			validateByTrigger('change')
		}
	}

	provide('k-radio-group-value', computed((): string | number => innerValue.value))
	provide('k-radio-group-disabled', resolvedGroupDisabled)
	provide('k-radio-group-size', computed((): string => props.size))
	provide('k-radio-group-shape', computed((): string => props.shape))
	provide('k-radio-group-icon-placement', computed((): string => props.iconPlacement))
	provide('k-radio-group-update', updateValue)
</script>

<template>
	<view
		class="kit-ui--root k-radio-group"
		:class="[
			`k-radio-group--${direction}`,
			`k-radio-group--${shape}`,
			{ 'k-radio-group--disabled': resolvedGroupDisabled }
		]"
		:style="wrapperThemeStyle"
	>
		<slot></slot>
	</view>
</template>

<style lang="scss">
	@import '../../theme/index.scss';

	.k-radio-group {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		width: 100%;

		&--vertical {
			flex-direction: column;
			align-items: flex-start;
		}

		&--disabled {
			opacity: 0.6;
		}

		&--button {
			flex-direction: row;
			flex-wrap: wrap;
		}
	}
</style>
