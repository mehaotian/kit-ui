<template>
	<!-- #ifdef APP -->
	<scroll-view style="flex: 1;">
	<!-- #endif -->
		<view class="page">
			<view class="page-header">
				<text class="page-title">Form|业务表单校验示例</text>
				<text class="page-desc">覆盖常见录入、失焦提示、提交反馈等业务场景</text>
			</view>

			<!-- 基础信息校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">基础信息校验</text>
					<text class="page-desc">手机号、邮箱、网址与年龄范围</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="factoryFormRef" :model="factoryForm" :rules="factoryRules" :disabled="factoryDisabled">
						<k-form-item label="手机号" prop="phone">
							<k-input v-model="factoryForm.phone" type="tel" placeholder="请输入手机号" />
						</k-form-item>
						<k-form-item label="邮箱" prop="email">
							<k-input v-model="factoryForm.email" placeholder="请输入邮箱" />
						</k-form-item>
						<k-form-item label="个人网站" prop="website">
							<k-input v-model="factoryForm.website" placeholder="https://example.com" />
						</k-form-item>
						<k-form-item label="年龄" prop="age">
							<k-input v-model="factoryForm.age" type="number" placeholder="请输入年龄（1-120）" />
						</k-form-item>
					</k-form>
					<view class="demo-actions">
						<k-button
							type="default"
							:text="factoryDisabled ? '当前禁用，点击启用' : '当前启用，点击禁用'"
							@click="toggleFactoryDisabled"
						/>
						<k-button type="primary" text="校验" @click="handleFactorySubmit" />
					</view>
					<text class="demo-tip">表单状态：{{ factoryDisabled ? '禁用中' : '可编辑' }}</text>
					<text class="demo-tip">校验结果：{{ factoryLog }}</text>
				</view>
			</view>

			<!-- 联系方式与数量 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">联系方式与数量</text>
					<text class="page-desc">手机号、邮箱、整数输入</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="typeFormRef" :model="typeForm" :rules="typeRules">
						<k-form-item label="手机号" prop="phone">
							<k-input v-model="typeForm.phone" type="tel" placeholder="请输入手机号" />
						</k-form-item>
						<k-form-item label="邮箱" prop="email">
							<k-input v-model="typeForm.email" placeholder="请输入邮箱" />
						</k-form-item>
						<k-form-item label="数量" prop="count">
							<k-input v-model="typeForm.count" type="number" placeholder="请输入整数数量" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="校验" @click="handleTypeSubmit" />
					<text class="demo-tip">校验结果：{{ typeLog }}</text>
				</view>
			</view>

			<!-- 正则校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">规则扩展校验</text>
					<text class="page-desc">pattern / regexp / len / enum / whitespace</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="patternFormRef" :model="patternForm" :rules="patternRules">
						<k-form-item label="验证码" prop="code">
							<k-input v-model="patternForm.code" placeholder="6 位数字" />
						</k-form-item>
						<k-form-item label="邮编" prop="zip">
							<k-input v-model="patternForm.zip" placeholder="regexp 别名" />
						</k-form-item>
						<k-form-item label="角色" prop="role">
							<k-input v-model="patternForm.role" placeholder="请输入 admin 或 user" />
						</k-form-item>
						<k-form-item label="昵称" prop="nickname">
							<k-input v-model="patternForm.nickname" placeholder="不能仅输入空格" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="校验" @click="handlePatternSubmit" />
					<text class="demo-tip">校验结果：{{ patternLog }}</text>
				</view>
			</view>

			<!-- 错误汇总 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">提交错误提示</text>
					<text class="page-desc">提交后统一查看字段错误信息</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="errorFormRef" :model="errorForm" :rules="errorRules">
						<k-form-item label="用户名" prop="username">
							<k-input v-model="errorForm.username" placeholder="必填" />
						</k-form-item>
						<k-form-item label="手机号" prop="phone">
							<k-input v-model="errorForm.phone" type="tel" placeholder="手机号" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="校验并输出错误" @click="handleErrorSubmit" />
					<text class="demo-tip">错误汇总：{{ errorSummary }}</text>
				</view>
			</view>

			<!-- 手动状态控制 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">手动状态控制</text>
					<text class="page-desc">通过 validate-status 手动切换 validating/error/success</text>
				</view>
				<view class="demo-content demo-column">
					<k-form :model="manualStatusForm">
						<k-form-item
							label="审批金额"
							prop="amount"
							:validate-status="manualStatusValue"
							:error-message="manualStatusMessage"
						>
							<k-input v-model="manualStatusForm.amount" type="number" placeholder="请输入审批金额" />
						</k-form-item>
					</k-form>
					<view class="demo-actions">
						<k-button type="default" text="置为校验中" @click="setManualStatusValidating" />
						<k-button type="danger" text="置为失败" @click="setManualStatusError" />
						<k-button type="success" text="置为成功" @click="setManualStatusSuccess" />
						<k-button type="default" text="恢复自动" @click="clearManualStatus" />
					</view>
					<text class="demo-tip">当前状态：{{ manualStatusLog }}</text>
				</view>
			</view>

			<!-- 文案优先级 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">文案优先级</text>
					<text class="page-desc">项级 message > 表单级 message > 默认文案</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="priorityFormRef" :model="priorityForm" :rules="priorityRules">
						<k-form-item label="申请人" prop="localFirst" :rules="priorityLocalRules">
							<k-input v-model="priorityForm.localFirst" placeholder="优先走项级文案" />
						</k-form-item>
						<k-form-item label="工号" prop="formFallback" :rules="priorityFallbackRules">
							<k-input v-model="priorityForm.formFallback" placeholder="项级无文案时回退表单级" />
						</k-form-item>
						<k-form-item label="备注" prop="defaultFallback" :rules="priorityDefaultRules">
							<k-input v-model="priorityForm.defaultFallback" placeholder="无配置时回退默认文案" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="校验文案优先级" @click="handlePrioritySubmit" />
					<text class="demo-tip">错误汇总：{{ priorityLog }}</text>
				</view>
			</view>

			<!-- 原生输入框校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">原生输入框校验</text>
					<text class="page-desc">适用于小程序原生输入控件</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="nativeFormRef" :model="nativeForm" :rules="nativeRules">
						<k-form-item label="手机号" prop="phone">
							<input
								class="demo-native-input"
								v-model="nativeForm.phone"
								type="tel"
								placeholder="请输入手机号，失焦后校验"
								@blur="onNativePhoneBlur"
							/>
						</k-form-item>
					</k-form>
					<k-button type="primary" text="提交" @click="handleNativeSubmit" />
					<text class="demo-tip">提交结果：{{ nativeLog }}</text>
				</view>
			</view>

			<!-- 失焦即时校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">失焦即时校验</text>
					<text class="page-desc">输入完成离开焦点后即时提示</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="blurFormRef" :model="blurForm" :rules="blurRules">
						<k-form-item label="用户名" prop="username">
							<k-input v-model="blurForm.username" placeholder="请输入用户名" />
						</k-form-item>
						<k-form-item label="邮箱" prop="email">
							<k-input v-model="blurForm.email" placeholder="请输入邮箱" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="提交" @click="handleBlurSubmit" />
					<text class="demo-tip">提示：可先输入后失焦查看提示，再点击提交。结果：{{ blurLog }}</text>
				</view>
			</view>

			<!-- 密码确认校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">密码确认校验</text>
					<text class="page-desc">确认密码需与密码保持一致</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="customFormRef" :model="customForm" :rules="customRules">
						<k-form-item label="密码" prop="password">
							<k-input v-model="customForm.password" type="password" show-password placeholder="至少 6 位" />
						</k-form-item>
						<k-form-item label="确认密码" prop="confirmPassword" :rules="confirmPasswordRules">
							<k-input v-model="customForm.confirmPassword" type="password" show-password placeholder="再次输入密码" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="提交" @click="handleCustomSubmit" />
					<text class="demo-tip">校验结果：{{ customLog }}</text>
				</view>
			</view>

			<!-- 选项控件校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">选项控件校验</text>
					<text class="page-desc">单选、多选、开关在 change 时即时校验</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="optionFormRef" :model="optionForm" :rules="optionRules">
						<k-form-item label="性别" prop="gender">
							<k-radio-group v-model="optionForm.gender">
								<k-radio name="male" label="男" />
								<k-radio name="female" label="女" />
							</k-radio-group>
						</k-form-item>
						<k-form-item label="兴趣" prop="hobbies">
							<k-checkbox-group v-model="optionForm.hobbies">
								<k-checkbox name="read" label="阅读" />
								<k-checkbox name="sport" label="运动" />
							</k-checkbox-group>
						</k-form-item>
						<k-form-item label="接收通知" prop="notify">
							<k-switch v-model="optionForm.notify" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="提交" @click="handleOptionSubmit" />
					<text class="demo-tip">校验结果：{{ optionLog }}</text>
				</view>
			</view>

			<!-- 异步可用性校验 -->
			<view class="section">
				<view class="section-title">
					<text class="title-text">异步可用性校验</text>
					<text class="page-desc">用户名失焦后优先 uni.request 远程查重，失败回退本地兜底</text>
				</view>
				<view class="demo-content demo-column">
					<k-form ref="asyncFormRef" :model="asyncForm" :rules="asyncRules">
						<k-form-item label="用户名" prop="username">
							<k-input v-model="asyncForm.username" placeholder="输入 admin 或 root 会提示占用" />
						</k-form-item>
					</k-form>
					<k-button type="primary" text="异步校验提交" @click="handleAsyncSubmit" />
					<text class="demo-tip">校验结果：{{ asyncLog }}</text>
				</view>
			</view>
		</view>
	<!-- #ifdef APP -->
	</scroll-view>
	<!-- #endif -->
</template>

<script setup lang="uts">
	import {
		ruleRequired,
		rulePhone,
		ruleEmail,
		ruleUrl,
		ruleRange,
		ruleLen,
		ruleEnum,
		ruleNoWhitespace,
		ruleMinLength,
		rulePattern,
		ruleWithTrigger,
		ruleCustom,
		ruleAsync
	} from '../../uni_modules/kit-ui/components/k-form/validators.uts'
	import { readModelProperty } from '../../uni_modules/kit-ui/components/k-form/form-utils.uts'

	type FactoryFormData = {
		phone : string
		email : string
		website : string
		age : string
	}

	type TypeFormData = {
		phone : string
		email : string
		count : string
	}

	type PatternFormData = {
		code : string
		zip : string
		role : string
		nickname : string
	}

	type ErrorFormData = {
		username : string
		phone : string
	}

	type ManualStatusFormData = {
		amount : string
	}

	type PriorityFormData = {
		localFirst : string
		formFallback : string
		defaultFallback : string
	}

	type NativeFormData = {
		phone : string
	}

	type BlurFormData = {
		username : string
		email : string
	}

	type CustomFormData = {
		password : string
		confirmPassword : string
	}

	type OptionFormData = {
		gender : string
		hobbies : (string | number)[]
		notify : boolean
	}

	type AsyncFormData = {
		username : string
	}

	const factoryFormRef = ref<KFormComponentPublicInstance | null>(null)
	const typeFormRef = ref<KFormComponentPublicInstance | null>(null)
	const patternFormRef = ref<KFormComponentPublicInstance | null>(null)
	const errorFormRef = ref<KFormComponentPublicInstance | null>(null)
	const priorityFormRef = ref<KFormComponentPublicInstance | null>(null)
	const nativeFormRef = ref<KFormComponentPublicInstance | null>(null)
	const blurFormRef = ref<KFormComponentPublicInstance | null>(null)
	const customFormRef = ref<KFormComponentPublicInstance | null>(null)
	const optionFormRef = ref<KFormComponentPublicInstance | null>(null)
	const asyncFormRef = ref<KFormComponentPublicInstance | null>(null)

	const factoryForm = reactive<FactoryFormData>({
		phone: '',
		email: '',
		website: '',
		age: ''
	})

	const factoryRules = {
		phone: [ruleRequired('请输入手机号'), rulePhone('')],
		email: [ruleRequired('请输入邮箱'), ruleEmail('')],
		website: [ruleUrl('请输入有效 URL')],
		age: [ruleRequired('请输入年龄'), ruleRange(1, 120, '')]
	}

	const typeForm = reactive<TypeFormData>({
		phone: '',
		email: '',
		count: ''
	})

	const typeRules = {
		phone: [{ required: true, type: 'phone', message: '手机号格式不正确' }],
		email: [{ required: true, type: 'email', message: '邮箱格式不正确' }],
		count: [{ required: true, type: 'integer', message: '请输入整数' }]
	}

	const patternForm = reactive<PatternFormData>({
		code: '',
		zip: '',
		role: '',
		nickname: ''
	})

	const patternRules = {
		code: [
			ruleRequired('请输入验证码'),
			ruleLen(6, '验证码为 6 位数字'),
			rulePattern('^\\d{6}$', '验证码为 6 位数字')
		],
		zip: [
			{ required: true, regexp: '^\\d{6}$', message: '邮编为 6 位数字' }
		],
		role: [
			ruleRequired('请输入角色'),
			ruleEnum(['admin', 'user'], '角色仅支持 admin 或 user')
		],
		nickname: [
			ruleRequired('请输入昵称'),
			ruleNoWhitespace('昵称不能仅输入空白字符')
		]
	}

	const errorForm = reactive<ErrorFormData>({
		username: '',
		phone: ''
	})

	const manualStatusForm = reactive<ManualStatusFormData>({
		amount: ''
	})

	const priorityForm = reactive<PriorityFormData>({
		localFirst: '',
		formFallback: '',
		defaultFallback: ''
	})

	const errorRules = {
		username: [ruleRequired('请输入用户名'), ruleMinLength(2, '')],
		phone: [ruleRequired(''), rulePhone('')]
	}

	const priorityRules = {
		localFirst: [
			{ required: true, message: '表单级：请输入申请人' }
		],
		formFallback: [
			{ required: true, message: '表单级：请输入工号' }
		]
	}

	const priorityLocalRules = [
		{ required: true, message: '项级：请输入申请人姓名' }
	]

	const priorityFallbackRules = [
		{ required: true }
	]

	const priorityDefaultRules = [
		{ required: true }
	]

	const nativeForm = reactive<NativeFormData>({
		phone: ''
	})

	const nativeRules = {
		phone: [ruleRequired('请输入手机号'), ruleWithTrigger(rulePhone(''), 'blur')]
	}

	const blurForm = reactive<BlurFormData>({
		username: '',
		email: ''
	})

	const blurRules = {
		username: [
			ruleRequired('请输入用户名'),
			ruleWithTrigger(ruleMinLength(2, '用户名至少 2 个字符'), 'blur')
		],
		email: [
			ruleRequired('请输入邮箱'),
			ruleWithTrigger(ruleEmail(''), 'blur')
		]
	}

	const customForm = reactive<CustomFormData>({
		password: '',
		confirmPassword: ''
	})

	const customRules = {
		password: [
			ruleRequired('请输入密码'),
			ruleWithTrigger(ruleMinLength(6, '密码至少 6 位'), 'blur')
		]
	}

	const optionForm = reactive<OptionFormData>({
		gender: '',
		hobbies: [],
		notify: false
	})

	const optionRules = {
		gender: [
			ruleWithTrigger({ required: true, message: '请选择性别' }, 'change')
		],
		hobbies: [
			ruleWithTrigger({ required: true, type: 'array', message: '请至少选择一项兴趣' }, 'change')
		],
		notify: [
			ruleCustom((value : any, _rule : any, _model : any | null) : boolean | string => {
				if (value == true) {
					return true
				}
				return '请开启接收通知'
			}, '', 'change')
		]
	}

	const asyncForm = reactive<AsyncFormData>({
		username: ''
	})

	/**
	 * 本地兜底：保留用户名列表（网络失败时保障示例可验证）
	 */
	const RESERVED_USERNAMES = ['admin', 'root', 'system']

	/**
	 * 本地兜底判断：命中保留用户名即视为占用
	 */
	function checkUsernameByFallback(username : string) : boolean | string {
		for (let i = 0; i < RESERVED_USERNAMES.length; i++) {
			if (RESERVED_USERNAMES[i] == username) {
				return '用户名已被占用'
			}
		}
		return true
	}

	/**
	 * 远程用户名可用性检查（优先 uni.request，失败自动回落本地兜底）
	 * 说明：示例使用 GitHub Users 接口，200 表示占用，404 表示可用。
	 */
	function requestUsernameAvailability(username : string) : Promise<boolean | string> {
		return new Promise((resolve : (value : boolean | string) => void) => {
			if (username == '') {
				resolve(true)
				return
			}
			let finished = false
			const finish = (result : boolean | string) => {
				if (!finished) {
					finished = true
					resolve(result)
				}
			}
			uni.request({
				url: `https://api.github.com/users/${username}`,
				method: 'GET',
				timeout: 2500,
				success: (res) => {
					const statusCode = res.statusCode
					if (statusCode == 404) {
						finish(true)
						return
					}
					if (statusCode == 200) {
						finish('用户名已被占用')
						return
					}
					finish(checkUsernameByFallback(username))
				},
				fail: () => {
					finish(checkUsernameByFallback(username))
				}
			})
		})
	}

	const asyncRules = {
		username: [
			ruleRequired('请输入用户名'),
			ruleWithTrigger(ruleMinLength(3, '用户名至少 3 个字符'), 'blur'),
			ruleAsync((value : any, _rule : any, _model : any | null) : Promise<boolean | string> => {
				const username = `${value}`.trim().toLowerCase()
				return requestUsernameAvailability(username)
			}, '用户名校验失败，请稍后重试', 'blur')
		]
	}

	/**
	 * 确认密码：项级 rules + ruleCustom 保留 validator 函数（APP 兼容）
	 */
	const confirmPasswordRules = [
		ruleWithTrigger(ruleRequired('请再次输入密码'), 'blur'),
		ruleCustom((value : any, _rule : any, model : any | null) : boolean | string => {
			if (model == null) {
				return true
			}
			const password = readModelProperty(model, 'password')
			if (password == null || password == '') {
				return true
			}
			if (value != password) {
				return '两次密码不一致'
			}
			return true
		}, '', 'blur')
	]

	const factoryLog = ref<string>('暂无')
	const factoryDisabled = ref<boolean>(false)
	const typeLog = ref<string>('暂无')
	const patternLog = ref<string>('暂无')
	const errorSummary = ref<string>('暂无')
	const manualStatusValue = ref<string>('')
	const manualStatusMessage = ref<string>('')
	const manualStatusLog = ref<string>('自动模式')
	const priorityLog = ref<string>('暂无')
	const nativeLog = ref<string>('暂无')
	const blurLog = ref<string>('暂无')
	const customLog = ref<string>('暂无')
	const optionLog = ref<string>('暂无')
	const asyncLog = ref<string>('暂无')

	/**
	 * 切换基础信息示例的禁用状态
	 */
	const toggleFactoryDisabled = () => {
		factoryDisabled.value = !factoryDisabled.value
	}

	/**
	 * 基础信息表单校验
	 */
	const handleFactorySubmit = () => {
		const valid = factoryFormRef.value?.validate?.() ?? false
		factoryLog.value = valid ? '校验通过' : '校验失败，请检查表单项'
	}

	/**
	 * 联系方式与数量表单校验
	 */
	const handleTypeSubmit = () => {
		const valid = typeFormRef.value?.validate?.() ?? false
		typeLog.value = valid ? '校验通过' : '校验失败，请检查表单项'
	}

	/**
	 * 正则规则表单校验
	 */
	const handlePatternSubmit = () => {
		const valid = patternFormRef.value?.validate?.() ?? false
		patternLog.value = valid ? '校验通过' : '校验失败，请检查表单项'
	}

	/**
	 * 校验并输出 getFieldsError 汇总
	 */
	const handleErrorSubmit = () => {
		const form = errorFormRef.value
		if (form == null) {
			return
		}
		const valid = form.validate?.() ?? false
		if (valid) {
			errorSummary.value = '校验通过'
			return
		}
		const errors = form.getFieldsError?.()
		errorSummary.value = errors != null ? JSON.stringify(errors) : '校验失败'
	}

	/**
	 * 手动切换为 validating 状态
	 */
	const setManualStatusValidating = () => {
		manualStatusValue.value = 'validating'
		manualStatusMessage.value = ''
		manualStatusLog.value = 'validating（手动）'
	}

	/**
	 * 手动切换为 error 状态
	 */
	const setManualStatusError = () => {
		manualStatusValue.value = 'error'
		manualStatusMessage.value = '审批金额超过当前权限上限'
		manualStatusLog.value = 'error（手动）'
	}

	/**
	 * 手动切换为 success 状态
	 */
	const setManualStatusSuccess = () => {
		manualStatusValue.value = 'success'
		manualStatusMessage.value = ''
		manualStatusLog.value = 'success（手动）'
	}

	/**
	 * 清空手动状态，恢复自动校验状态
	 */
	const clearManualStatus = () => {
		manualStatusValue.value = ''
		manualStatusMessage.value = ''
		manualStatusLog.value = '自动模式'
	}

	/**
	 * 校验文案优先级示例提交
	 */
	const handlePrioritySubmit = () => {
		const form = priorityFormRef.value
		if (form == null) {
			return
		}
		const valid = form.validate?.() ?? false
		if (valid) {
			priorityLog.value = '校验通过'
			return
		}
		const errors = form.getFieldsError?.()
		priorityLog.value = errors != null ? JSON.stringify(errors) : '校验失败'
	}

	/**
	 * 原生输入框失焦触发手机号校验
	 */
	const onNativePhoneBlur = () => {
		const form = nativeFormRef.value
		if (form != null) {
			form.validateField('phone', 'blur')
		}
	}

	/**
	 * 原生输入框表单提交
	 */
	const handleNativeSubmit = () => {
		const valid = nativeFormRef.value?.validate?.() ?? false
		nativeLog.value = valid ? '校验通过' : '校验失败，请检查手机号'
	}

	/**
	 * 失焦即时校验示例提交
	 */
	const handleBlurSubmit = () => {
		const valid = blurFormRef.value?.validate?.() ?? false
		blurLog.value = valid ? '校验通过' : '校验失败，请检查表单项'
	}

	/**
	 * 密码确认校验示例提交
	 */
	const handleCustomSubmit = () => {
		const valid = customFormRef.value?.validate?.() ?? false
		customLog.value = valid ? '校验通过' : '校验失败，请检查密码'
	}

	/**
	 * 选项控件校验示例提交
	 */
	const handleOptionSubmit = () => {
		const valid = optionFormRef.value?.validate?.() ?? false
		optionLog.value = valid ? '校验通过' : '校验失败，请检查选项'
	}

	/**
	 * 异步可用性校验示例提交
	 */
	const handleAsyncSubmit = () => {
		const form = asyncFormRef.value
		if (form == null) {
			return
		}
		asyncLog.value = '校验中...'
		form.validateAsync().then((valid : boolean) => {
			asyncLog.value = valid ? '校验通过' : '校验失败，请检查用户名'
		}).catch((_err) => {
			asyncLog.value = '校验失败，请稍后重试'
		})
	}
</script>

<style lang="scss">
	.demo-column .k-form {
		margin-bottom: 12px;
		width: 100%;
	}

	.demo-column .k-input-wrapper {
		width: 100%;
	}

	.demo-tip {
		font-size: 12px;
		color: var(--k-text-color-secondary, #6b7280);
	}

	.demo-actions {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
	}

	.demo-actions .k-button {
		margin-right: 8px;
		margin-bottom: 8px;
	}

	.demo-native-input {
		width: 100%;
		box-sizing: border-box;
		min-height: 40px;
		padding-top: var(--k-spacing-sm, 8px);
		padding-bottom: var(--k-spacing-sm, 8px);
		padding-left: var(--k-spacing-base, 12px);
		padding-right: var(--k-spacing-base, 12px);
		border-width: 1px;
		border-style: solid;
		border-color: var(--k-border-color, #e5e7eb);
		border-radius: var(--k-border-radius-base, 8px);
		font-size: var(--k-font-size-base, 14px);
		color: var(--k-text-color, #374151);
	}
</style>
