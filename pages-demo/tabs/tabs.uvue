	/**
	 * 懒加载演示：已访问 Tab 列表文案
	 */
	const lazyVisitedText = computed((): string => {
		return lazyVisited.value.join('、')
	})

	/**
	 * 懒加载 Tab 切换时记录访问
	 */
	const handleLazyChange = (name : string | number, _index : number) => {
		const key = `${name}`
		if (!lazyVisited.value.includes(key)) {
			lazyVisited.value.push(key)
		}
	}

	/**
	 * 记录基础用法 change 事件
	 */
	const handleBasicChange = (name : string | number, index : number) => {
		console.log('tabs change', name, index)
	}

	/**
	 * 拦截切换到 locked Tab
	 */
	const handleBeforeChange = (name : string | number, index : number) : boolean => {
		if (name == 'locked') {
			return false
		}
		return true
	}
</script>

