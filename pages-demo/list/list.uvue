		margin-bottom: 8px;
	}

	.demo-order-card__price {
		font-size: 16px;
		color: #6366f1;
		font-weight: bold;
	}

	.demo-custom-loading {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 32px 16px;
	}

	.demo-custom-loading__spinner {
		width: 24px;
		height: 24px;
		min-width: 24px;
		min-height: 24px;
		flex-shrink: 0;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}

	.demo-custom-loading__text {
		font-size: 14px;
		color: #969799;
		margin-top: 12px;
	}

	.demo-custom-error {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 32px 16px;
	}

	.demo-custom-error__text {
		font-size: 14px;
		color: #969799;
		margin-top: 12px;
		margin-bottom: 12px;
	}

	.demo-custom-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 32px 16px;
	}

	.demo-custom-empty__text {
		font-size: 15px;
		color: #323233;
		margin-top: 16px;
	}

	.demo-custom-empty__hint {
		font-size: 12px;
		color: #969799;
		margin-top: 8px;
	}

	.demo-custom-footer {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		padding: 16px;
		background-color: #fafafa;
	}

	.demo-custom-footer__text {
		font-size: 12px;
